# Copie para .env e preencha com suas chaves

# Provider padrao: mock | openai | ollama | anthropic
DEFAULT_PROVIDER=ollama

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-3-5-haiku-20241022

# Ollama local (OpenAI-compatible)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_DEFAULT_MODEL=gpt-oss:20b

# Judge (provider/modelo usado para LLM-as-judge)
JUDGE_PROVIDER=ollama
JUDGE_MODEL=gpt-oss:20b
JUDGE_RUBRIC_DEFAULT=balanced

# Banco de dados
DATABASE_URL=sqlite:///./data/aievals.db

# Observabilidade
LOG_LEVEL=INFO
OTEL_ENABLED=false

# App
APP_SECRET_KEY=troque-isso-em-producao
DEBUG=false
